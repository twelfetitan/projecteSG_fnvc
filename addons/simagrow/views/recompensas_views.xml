<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- VISTA BÚSQUEDA CON FILTROS POR TIPO -->
        <record id="view_recompensas_search" model="ir.ui.view">
            <field name="name">simagrow.recompensas.search</field>
            <field name="model">simagrow.recompensas</field>
            <field name="arch" type="xml">
                <search string="Buscar Recompensas">
                    <field name="nombre" string="Nombre" />
                    <filter name="filamento" string="Filamento" domain="[('tipo', '=', 'filamento')]" />
                    <filter name="merchandising" string="Merchandising" domain="[('tipo', '=', 'merchandising')]" />
                    <filter name="snacks" string="Snacks" domain="[('tipo', '=', 'snacks')]" />
                    <group expand="0" string="Agrupar por">
                        <filter name="group_tipo" string="Tipo" context="{'group_by': 'tipo'}" />
                    </group>
                </search>
            </field>
        </record>

        <!-- VISTA LISTA -->
        <record id="view_recompensas_list" model="ir.ui.view">
            <field name="name">simagrow.recompensas.list</field>
            <field name="model">simagrow.recompensas</field>
            <field name="arch" type="xml">
                <list string="Recompensas">
 
                    <field name= "idRecompensa" />
                    <field name="nombre" string="Nombre" />
                    <field name="tipo" string="Tipo" />
                    <field name="tokens" string="Tokens" />
                </list>
            </field>
        </record>

        <!-- VISTA FORMULARIO -->
        <record id="view_recompensas_form" model="ir.ui.view">
            <field name="name">simagrow.recompensas.form</field>
            <field name="model">simagrow.recompensas</field>
            <field name="arch" type="xml">
                <form string="Recompensa">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="nombre" placeholder="Nombre de la recompensa" /></h1>
                        </div>
                        <div class="row mt16">
                            <div class="col-md-4 text-center">
                                <field name="imagen"
                                       widget="image"
                                       options="{'size': [200, 200]}" />
                            </div>
                            <div class="col-md-8">
                                <group string="Detalles">
                                    <field name="tipo" string="Tipo" />
                                    <field name="tokens" string="Tokens necesarios" />
                                </group>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>