<odoo>
    <data>

        <!-- WIZARD FORM -->
        <record id="view_canje_recompensa_wizard_form" model="ir.ui.view">
            <field name="name">simagrow.canje_recompensa.wizard.form</field>
            <field name="model">simagrow.canje_recompensa.wizard</field>
            <field name="arch" type="xml">
                <form string="Canjear Recompensa">
                    <sheet>
                        <group>
                            <field name="usuario_id" readonly="1" />
                            <field name="tokens_disponibles" />
                            <field name="recompensa_id" domain="[('tokens', '&lt;=', tokens_disponibles)]" options="{'no_create': True, 'no_open': True}" />
                            <field name="tokens_requeridos" invisible="not recompensa_id" />
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_canjear" string="Canjear" type="object" class="btn-primary" />
                        <button string="Cancelar" class="btn-secondary" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <!-- WIZARD ACTION -->
        <record id="action_canje_recompensa_wizard" model="ir.actions.act_window">
            <field name="name">Canjear Recompensa</field>
            <field name="res_model">simagrow.canje_recompensa.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!--LISTA-->
        <record id="view_usuario_list" model="ir.ui.view">
            <field name="name">simagrow.usuario.list</field>
            <field name="model">simagrow.usuario</field>
            <field name="arch" type="xml">
                <list>
                    <field name="idUsuario" string="ID" />
                    <field name="nombre" />
                    <field name="apellidos" />
                    
                    <field name="creditos" string="Créditos" />
                </list>
            </field>
        </record>

        <!--FORM-->
        <record id="view_usuario_form" model="ir.ui.view">
            <field name="name">simagrow.usuario.form</field>
            <field name="model">simagrow.usuario</field>
            <field name="arch" type="xml">
                <form string="Usuario">
                    <header>
                        <button name="%(simagrow.action_canje_recompensa_wizard)d" 
                                string="Canjear Recompensa" 
                                type="action" 
                                class="btn-primary" />
                    </header>
                    <sheet>
                        <group>
                            <field name="idUsuario" string="ID Usuario" />
                            <field name="nombre" />
                            <field name="apellidos" />
                            <field name="nif" string="NIF" />
                            <field name="correo" string="Correo" />
                            <field name="contrasena" string="Contraseña" />
                            <field name="fecha_nacimiento" string="Fecha de Nacimiento" />
                            <field name="creditos" string="Créditos" />
                            <field name="admin" string="Administrador" />
                        </group>
                        <notebook>
                            <page string="Incidencias">
                                <field name="incidencia_ids" />
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!--KANBAN-->

        <record id="view_usuario_kanban" model="ir.ui.view">
            <field name="name">simagrow.usuario.kanban</field>
            <field name="model">simagrow.usuario</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="idUsuario" />
                    <field name="nombre" />
                    <field name="apellidos" />
                    <field name="correo" />
                    <field name="contrasena" />
                    <field name="fecha_nacimiento" />
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <strong>
                                    <t t-esc="record.nombre.value" />
                                </strong>
                                <br />
                                <t t-esc="record.apellidos.value" />
                                <br />
                                <small>ID: <t t-esc="record.idUsuario.value" /></small>
                                <br />
                                <small>
                                    <t t-esc="record.fecha_nacimiento.value" />
                                </small>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

    </data>



</odoo>